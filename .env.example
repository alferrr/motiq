MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=''
MYSQL_DATABASE=motiq

JWT_SECRET=your_jwt_secret_key_here

# 32-byte key (base64) used to encrypt secrets stored in the DB, e.g. each
# company's linked Kasa secret key. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Email of the account allowed to edit landing-page content via the /content
# CMS. Must match the Email of an existing User row (any role/company) —
# reuses the existing login, not a separate password gate.
OWNER_EMAIL=

# Kasa Dashboard (payment gateway) integration — each company links its own
# account via "Sign in with Kasa" (OAuth) from Settings > Kasa Payments,
# stored encrypted in the DB. Only the shared Dashboard URL + this app's own
# OAuth client credentials (registered with Kasa Dashboard) are needed here.
KASA_BASE_URL=http://localhost:3001
KASA_OAUTH_CLIENT_ID=
KASA_OAUTH_CLIENT_SECRET=

# Resend (transactional email) integration
# Create an API key at https://resend.com/api-keys and paste it here
RESEND_API_KEY=
# Must be on a domain verified in Resend; falls back to Resend's sandbox sender if unset
RESEND_FROM_EMAIL=Motiq <notifications@alfermercado.com>
